{
  "name": "spotify-playlist-organizer",
  "displayName": "Playlist organizer for Spotify",
  "version": "1.0.1",
  "description": "Organize your spotify playlist.",
  "author": "k7nghost",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "icons": {
      "16": "../assets/logo.png",
      "32": "../assets/logo.png",
      "48": "../assets/logo.png",
      "128": "../assets/logo.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "../assets/logo.png",
        "32": "../assets/logo.png",
        "48": "../assets/logo.png",
        "128": "../assets/logo.png"
      }
    },
    "permissions": [
      "storage",
      "webRequest",
      "tabs"
    ],
    "host_permissions": [
      "https://api.spotify.com/*",
      "https://api-partner.spotify.com/*",
      "https://open.spotify.com/*"
    ]
  }
}
